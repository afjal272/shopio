generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String   @id @default(uuid())
  title         String
  brand         String?
  price         Int
  rating        Float
  reviewsCount  Int      @default(0)
  image         String?
  tags          String[]
  specs         Json
  createdAt     DateTime @default(now())
}