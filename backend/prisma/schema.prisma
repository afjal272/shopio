generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(uuid())

  name          String   // was title
  brand         String   // now required

  price         Int
  discountPrice Int?     // new

  rating        Float
  reviewsCount  Int      @default(0)

  images        String[] // replaced image

  description   String   // new (important for detail page)
  category      String   // new

  tags          String[]
  highlights    String[] // new
  weaknesses    String[] // new

  createdAt     DateTime @default(now())
}