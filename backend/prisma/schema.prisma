generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(uuid())
  brand         String
  price         Int
  rating        Float
  reviewsCount  Int      @default(0)
  tags          String[]
  specs         Json
  createdAt     DateTime @default(now())
  category      String
  description   String
  discountPrice Int?
  highlights    String[]
  images        String[]
  name          String
  updatedAt     DateTime @updatedAt
  weaknesses    String[]
}
