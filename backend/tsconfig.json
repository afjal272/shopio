{
  "compilerOptions": {
    /* Core */
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Dev Experience */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Fix for your error */
    "verbatimModuleSyntax": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}