{
  "compilerOptions": {
    "target": "ES2020",

    /* 🔥 Modern setup */
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness */
    "strict": true,

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Dev */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}